package Integers;

public class LoopBased {

	public static void main(String[] args) {

		// Print numbers from 1 to n
		for (int i = 1; i <= 5; i++) {
			System.out.print(i + " ");
		}
		
		System.out.println();
		
		// Print numbers from n to 1
		for (int i = 5; i >= 1; i--) {
			System.out.print(i + " ");
		}

	}

}
