package Wrapper;

public class SwitchEx {

	public static void main(String[] args) {
		int input=1;
		switch(input) {
		case 2:
			System.out.println("This is 2");
			input =3;
			break;
		case 1:
			System.out.println("This is 1");
			input++;
			break;
			default: 
				System.out.println("This is 3");
		}
	}

}
